            row.pack(fill="x", padx=6, pady=4)
            tk.Label(row, text=name, bg=C_CARD, fg=col,
                     font=("Arial", 10, "bold"), width=14,
                     anchor="w").pack(side="left")
            lbl = tk.Label(row, text="0", bg=C_CARD, fg="white",
                           font=("Arial", 18, "bold"), width=5,
                           anchor="e")
            lbl.pack(side="right", padx=8)
            self.counter_labels[key] = lbl

