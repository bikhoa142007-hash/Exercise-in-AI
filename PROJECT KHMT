        self._set_mode("login")

    def _tab_btn(self, parent, text, cmd):
        return tk.Button(parent, text=text, bg=C_CARD, fg=C_TEXT,
                         font=("Arial", 9, "bold"), relief="flat",
                         padx=10, pady=5, cursor="hand2",
                         activebackground=C_BLUE, activeforeground="white",
                         command=cmd)

    def _styled_entry(self, parent, show=None):
        e = tk.Entry(parent, bg=C_ENTRY_BG, fg=C_TEXT,
                     insertbackground=C_TEXT,
                     relief="flat", font=("Arial", 11),
                     show=show or "")
        e.config(highlightthickness=1,
                 highlightbackground=C_BORDER,
                 highlightcolor=C_BLUE)
        return e

    def _label(self, parent, text):
        return tk.Label(parent, text=text, bg=C_BG, fg=C_SUBTEXT,
                        font=("Arial", 9))

    # ── Set active mode ───────────────────────────
    def _set_mode(self, mode):
        self.mode = mode

        # Update welcome text on left panel
        msg_map = {
            "login":    "Chào mừng bạn quay trở lại! 👋",
            "register": "Tài khoản của bạn đã sẵn sàng ✅",
            "forgot":   "Khôi phục tài khoản 🔑",
        }
        self.welcome_var.set(msg_map[mode])

        # Highlight active tab
        for btn, m in [(self.btn_login, "login"),
                       (self.btn_register, "register"),
                       (self.btn_forgot, "forgot")]:
            if m == mode:
                btn.config(bg=C_RED, fg="white")
            else:
                btn.config(bg=C_CARD, fg=C_TEXT)

        # Clear form
        for w in self.form_frame.winfo_children():
            w.destroy()
        self.status_var.set("")

        if mode == "login":
            self._label(self.form_frame, "Tên đăng nhập").pack(anchor="w", pady=(0, 2))
            self.e_user = self._styled_entry(self.form_frame)
            self.e_user.pack(fill="x", ipady=5, pady=(0, 8))

            self._label(self.form_frame, "Mật khẩu").pack(anchor="w", pady=(0, 2))
            self.e_pass = self._styled_entry(self.form_frame, show="●")
            self.e_pass.pack(fill="x", ipady=5)

        elif mode == "register":
            self._label(self.form_frame, "Tên đăng nhập").pack(anchor="w", pady=(0, 2))
            self.e_user = self._styled_entry(self.form_frame)
            self.e_user.pack(fill="x", ipady=5, pady=(0, 6))

            self._label(self.form_frame, "Mật khẩu").pack(anchor="w", pady=(0, 2))
            self.e_pass = self._styled_entry(self.form_frame, show="●")
            self.e_pass.pack(fill="x", ipady=5, pady=(0, 6))

            self._label(self.form_frame, "Xác nhận mật khẩu").pack(anchor="w", pady=(0, 2))
            self.e_confirm = self._styled_entry(self.form_frame, show="●")
            self.e_confirm.pack(fill="x", ipady=5)

        elif mode == "forgot":
            self._label(self.form_frame, "Tên đăng nhập").pack(anchor="w", pady=(0, 2))
            self.e_user = self._styled_entry(self.form_frame)
            self.e_user.pack(fill="x", ipady=5, pady=(0, 6))

            self._label(self.form_frame, "Mật khẩu mới").pack(anchor="w", pady=(0, 2))
            self.e_pass = self._styled_entry(self.form_frame, show="●")
            self.e_pass.pack(fill="x", ipady=5)

        # Show Enter button
        self.enter_btn.place(relx=0.5, rely=0.78, anchor="center", width=160, height=36)

    # ── Enter button handler ──────────────────────
    def _on_enter(self):
        self.users = load_users()
        if self.mode == "login":
            self._do_login()
        elif self.mode == "register":
            self._do_register()
        elif self.mode == "forgot":
            self._do_forgot()

    def _do_login(self):
        u = self.e_user.get().strip()
        p = self.e_pass.get()
        if not u or not p:
            self._show_status("Vui lòng nhập đầy đủ thông tin.", error=True)
            return
        if u in self.users and self.users[u]["password"] == hash_password(p):
            self._show_status("Đăng nhập thành công!", error=False)
            self.master.after(600, lambda: self.on_login_success(u))
        else:
            self._show_status("Sai tên đăng nhập hoặc mật khẩu.", error=True)

    def _do_register(self):
        u = self.e_user.get().strip()
        p = self.e_pass.get()
        c = self.e_confirm.get()
        if not u or not p:
            self._show_status("Vui lòng nhập đầy đủ thông tin.", error=True)
            return
        if p != c:
            self._show_status("Mật khẩu xác nhận không khớp.", error=True)
            return
        if u in self.users:
            self._show_status("Tên đăng nhập đã tồn tại.", error=True)
            return
        self.users[u] = {"password": hash_password(p), "created": datetime.now().isoformat()}
        save_users(self.users)
        self._show_status(f"Đăng ký thành công! Xin chào {u} 🎉", error=False)

    def _do_forgot(self):
        u = self.e_user.get().strip()
        p = self.e_pass.get()
        if not u or not p:
            self._show_status("Vui lòng nhập đầy đủ thông tin.", error=True)
            return
        if u not in self.users:
            self._show_status("Tên đăng nhập không tồn tại.", error=True)
            return
        self.users[u]["password"] = hash_password(p)
        save_users(self.users)
        self._show_status("Mật khẩu đã được cập nhật thành công ✅", error=False)

    def _show_status(self, msg, error=False):
        self.status_var.set(msg)
        self.status_lbl.config(fg=C_ERROR if error else C_SUCCESS)


