        tk.Button(row2, text="↺  Làm mới cổng",
                  bg=C_BLUE, fg="white",
                  font=("Arial", 9), relief="flat",
                  cursor="hand2", padx=10, pady=4,
                  command=self._refresh_ports).pack(side="left", padx=4)

