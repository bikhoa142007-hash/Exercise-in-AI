        tk.Label(topbar, text=f"👤 {self.username}",
                 bg=C_RED, fg="white",
                 font=("Arial", 10)).pack(side="right", padx=16)

        # Color indicator strip
        strip = tk.Frame(self, height=4, bg=C_BG)
        strip.pack(fill="x")
        for col in [C_RED, C_BLUE, C_GREEN]:
            tk.Frame(strip, height=4, bg=col, width=WIN_W//3).pack(side="left")

        # ── MAIN CONTENT ─────────────────────────
        content = tk.Frame(self, bg=C_BG)
        content.pack(fill="both", expand=True, padx=16, pady=12)

        # LEFT: Arduino connection + serial log
        left_col = tk.Frame(content, bg=C_BG)
        left_col.pack(side="left", fill="both", expand=True, padx=(0, 10))

        # Connection card
        conn_card = self._card(left_col, "🔌  Kết nối Arduino")
        conn_card.pack(fill="x", pady=(0, 10))

        row1 = tk.Frame(conn_card, bg=C_CARD)
