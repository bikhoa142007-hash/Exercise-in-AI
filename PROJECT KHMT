class App(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("IT Blind Club — Conveyor Classification System")
        self.geometry(f"{WIN_W}x{WIN_H}")
        self.resizable(False, False)
        self.configure(bg=C_BG)

        # Style for combobox
        style = ttk.Style(self)
        style.theme_use("clam")
        style.configure("TCombobox",
                        fieldbackground=C_ENTRY_BG,
                        background=C_ENTRY_BG,
                        foreground=C_TEXT,
                        selectbackground=C_BLUE,
                        selectforeground="white",
                        bordercolor=C_BORDER,
                        arrowcolor=C_TEXT)

        self.current_frame = None
        self.show_login()

    def show_login(self):
        if self.current_frame:
            self.current_frame.destroy()
        self.current_frame = LoginWindow(self, on_login_success=self.show_arduino)

    def show_arduino(self, username):
        if self.current_frame:
            self.current_frame.destroy()
        self.current_frame = ArduinoWindow(self, username)


if __name__ == "__main__":
    app = App()
    app.mainloop()
