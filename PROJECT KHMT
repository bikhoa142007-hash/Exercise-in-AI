                                      highlightthickness=0,
                                      width=210, height=200)
        self.gauge_canvas.pack(padx=6, pady=6)
        self._draw_gauge()

        # Reset + logout buttons
        btn_row = tk.Frame(right_col, bg=C_BG)
        btn_row.pack(fill="x", pady=6)
        tk.Button(btn_row, text="🔄 Reset",
                  bg=C_CARD, fg=C_TEXT,
                  font=("Arial", 9), relief="flat",
                  cursor="hand2", padx=10, pady=5,
                  command=self._reset_counters).pack(side="left", padx=(0, 6))
        tk.Button(btn_row, text="🚪 Đăng xuất",
                  bg=C_RED, fg="white",
                  font=("Arial", 9, "bold"), relief="flat",
                  cursor="hand2", padx=10, pady=5,
                  command=self._logout).pack(side="right")

    def _card(self, parent, title):
        frame = tk.Frame(parent, bg=C_CARD, bd=0,
                         highlightthickness=1,
                         highlightbackground=C_BORDER)
        tk.Label(frame, text=title, bg=C_CARD, fg=C_ACCENT,
                 font=("Arial", 10, "bold"),
                 anchor="w", padx=8, pady=6).pack(fill="x")
        tk.Frame(frame, height=1, bg=C_BORDER).pack(fill="x")
        return frame

    def _refresh_ports(self):
        if SERIAL_AVAILABLE:
            ports = [p.device for p in serial.tools.list_ports.comports()]
        else:
            ports = ["COM1", "COM2", "COM3", "/dev/ttyUSB0", "/dev/ttyACM0"]
        self.port_combo["values"] = ports
        if ports:
            self.port_var.set(ports[0])

    def _toggle_connect(self):
        if self.ser and self.ser.is_open:
            self._disconnect()
        else:
            self._connect()

    def _connect(self):
        if not SERIAL_AVAILABLE:
            self._append_log("⚠  pyserial chưa được cài. Chạy: pip install pyserial\n", "info_tag")
            # Demo mode
            self.conn_status.config(text="● Demo mode (không có pyserial)", fg=C_ACCENT)
            self.btn_connect.config(text="⏹  Dừng demo", bg=C_RED, fg="white")
            self.reading = True
            threading.Thread(target=self._demo_read, daemon=True).start()
            return
        port = self.port_var.get()
        baud = int(self.baud_var.get())
        try:
            self.ser = serial.Serial(port, baud, timeout=1)
            self.reading = True
            self.conn_status.config(text=f"● Đã kết nối {port}", fg=C_GREEN)
            self.btn_connect.config(text="⏹  Ngắt kết nối", bg=C_RED, fg="white")
            self._append_log(f"[{self._ts()}] ✅ Kết nối {port} @ {baud} baud\n", "info_tag")
            threading.Thread(target=self._read_serial, daemon=True).start()
        except Exception as ex:
            self._append_log(f"[{self._ts()}] ❌ Lỗi: {ex}\n", "info_tag")
            messagebox.showerror("Lỗi kết nối", str(ex))

    def _disconnect(self):
        self.reading = False
        if self.ser:
            self.ser.close()
            self.ser = None
        self.conn_status.config(text="● Đã ngắt kết nối", fg=C_ERROR)
        self.btn_connect.config(text="▶  Kết nối", bg=C_GREEN, fg=C_BG)
        self._append_log(f"[{self._ts()}] 🔌 Ngắt kết nối\n", "info_tag")

    def _read_serial(self):
        while self.reading and self.ser and self.ser.is_open:
            try:
                line = self.ser.readline().decode("utf-8", errors="ignore").strip()
                if line:
                    self.master.after(0, self._process_line, line)
            except Exception:
                break

    def _demo_read(self):
        """Simulate Arduino data for demo purposes."""
        import random
        colors = ["RED", "BLUE", "GREEN"]
        while self.reading:
            time.sleep(1.2)
            color = random.choice(colors)
            sensor = round(random.uniform(0.1, 3.3), 2)
            line = f"{color}:{sensor}"
            self.master.after(0, self._process_line, line)

    def _process_line(self, line):
        upper = line.upper()
        tag = "info_tag"
        if "RED" in upper:
            self.counters["red"] += 1
            tag = "red_tag"
        elif "BLUE" in upper:
            self.counters["blue"] += 1
            tag = "blue_tag"
        elif "GREEN" in upper:
            self.counters["green"] += 1
            tag = "green_tag"

        self._append_log(f"[{self._ts()}]  {line}\n", tag)
        self._update_counters()
        self._draw_gauge()

    def _append_log(self, msg, tag="info_tag"):
        self.log_text.config(state="normal")
        self.log_text.insert("end", msg, tag)
        self.log_text.see("end")
        self.log_text.config(state="disabled")

    def _send_command(self):
        cmd = self.cmd_entry.get().strip()
        if not cmd:
            return
        if self.ser and self.ser.is_open:
            self.ser.write((cmd + "\n").encode())
            self._append_log(f"[{self._ts()}] >> {cmd}\n", "info_tag")
        else:
            self._append_log(f"[{self._ts()}] ⚠  Chưa kết nối Arduino\n", "info_tag")
        self.cmd_entry.delete(0, "end")

    def _update_counters(self):
        for key, lbl in self.counter_labels.items():
            lbl.config(text=str(self.counters[key]))

    def _reset_counters(self):
        self.counters = {"red": 0, "blue": 0, "green": 0}
        self._update_counters()
        self._draw_gauge()

    def _draw_gauge(self):
        c = self.gauge_canvas
        c.delete("all")
        cx, cy, r = 105, 105, 80
        total = sum(self.counters.values()) or 1
        colors_map = [("red", C_RED), ("blue", C_BLUE), ("green", C_GREEN)]

        start = -90
        for key, col in colors_map:
            extent = (self.counters[key] / total) * 360
            if extent > 0:
                c.create_arc(cx-r, cy-r, cx+r, cy+r,
                             start=start, extent=extent,
                             fill=col, outline=C_CARD, width=2)
                start += extent

        # Center hole
        c.create_oval(cx-38, cy-38, cx+38, cy+38,
                      fill=C_CARD, outline=C_CARD)
        c.create_text(cx, cy-8, text=str(sum(self.counters.values())),
                      fill="white", font=("Arial", 16, "bold"))
        c.create_text(cx, cy+12, text="tổng", fill=C_SUBTEXT,
                      font=("Arial", 8))

        # Legend
        for i, (key, col) in enumerate(colors_map):
            lx, ly = 10, 175 - i * 18
            c.create_rectangle(lx, ly, lx+12, ly+12, fill=col, outline="")
            pct = round(self.counters[key] / total * 100) if total > 1 else 0
            c.create_text(lx+18, ly+6, anchor="w",
                          text=f"{key.capitalize()}: {pct}%",
                          fill=C_TEXT, font=("Arial", 8))

    def _logout(self):
        if self.reading:
            self._disconnect()
        self.master.show_login()

    def _ts(self):
        return datetime.now().strftime("%H:%M:%S")


