        self.master = master
        self.username = username
        self.pack_propagate(False)
        self.pack(fill="both", expand=True)

        self.ser = None
        self.reading = False
        self.data_buffer = []
        self.counters = {"red": 0, "blue": 0, "green": 0}

        self._build_ui()

    def _build_ui(self):
        # ── TOP BAR ──────────────────────────────
        topbar = tk.Frame(self, bg=C_RED, height=48)
        topbar.pack(fill="x")
        topbar.pack_propagate(False)

        tk.Label(topbar, text="⚙  IT Blind Club — Hệ thống phân loại băng truyền",
                 bg=C_RED, fg="white",
