class LabeledSlider(tk.Frame):
    """Slider kèm nhãn và giá trị hiển thị."""
    def __init__(self, parent, label, from_, to, resolution=1,
                 unit="", fmt=None, **kw):
        super().__init__(parent, bg=COLORS["surface"], **kw)
        self.fmt = fmt or (lambda v: f"{v:.0f}{unit}")
        tk.Label(self, text=label, font=FONT_SMALL,
                 bg=COLORS["surface"], fg=COLORS["text_muted"]).pack(anchor="w")
        row = tk.Frame(self, bg=COLORS["surface"])
        row.pack(fill="x")
        self.var = tk.DoubleVar()
        self.lbl = tk.Label(row, font=("Segoe UI", 10, "bold"),
                            bg=COLORS["surface"], fg=COLORS["accent"],
                            width=10, anchor="e")
        self.lbl.pack(side="right", padx=(6, 0))
        self.slider = tk.Scale(
            row, variable=self.var, from_=from_, to=to,
            resolution=resolution, orient="horizontal",
            showvalue=False, bg=COLORS["surface"],
            troughcolor=COLORS["accent_light"], activebackground=COLORS["accent"],
            highlightthickness=0, bd=0,
            command=self._on_change
        )
        self.slider.pack(side="left", fill="x", expand=True)
        self.var.set((from_ + to) / 2)
        self._on_change(self.var.get())

    def _on_change(self, v):
        self.lbl.config(text=self.fmt(float(v)))

    def get(self):
        return self.var.get()


class ToggleButton(tk.Frame):
    """Nút bật/tắt (Có / Không)."""
    def __init__(self, parent, label, **kw):
        super().__init__(parent, bg=COLORS["surface"], **kw)
        self.value = tk.BooleanVar(value=True)
        tk.Label(self, text=label, font=FONT_SMALL,
                 bg=COLORS["surface"], fg=COLORS["text_muted"]).pack(anchor="w")
        row = tk.Frame(self, bg=COLORS["surface"])
        row.pack(fill="x")
        self.btn_yes = tk.Button(row, text="✓  Có", font=FONT_SMALL,
                                 command=lambda: self._set(True), width=7,
                                 relief="flat", bd=0, cursor="hand2")
        self.btn_no  = tk.Button(row, text="✗  Không", font=FONT_SMALL,
                                 command=lambda: self._set(False), width=9,
                                 relief="flat", bd=0, cursor="hand2")
        self.btn_yes.pack(side="left", padx=(0, 4))
        self.btn_no.pack(side="left")
        self._set(True)

    def _set(self, val: bool):
        self.value.set(val)
        if val:
            self.btn_yes.config(bg=COLORS["accent"], fg="white")
            self.btn_no.config(bg=COLORS["surface2"], fg=COLORS["text_muted"])
        else:
            self.btn_yes.config(bg=COLORS["surface2"], fg=COLORS["text_muted"])
            self.btn_no.config(bg=COLORS["danger"], fg="white")

    def get(self) -> bool:
        return self.value.get()


