    def _draw_chart(self):
        for w in self.chart_frame.winfo_children():
            w.destroy()

        fig = Figure(figsize=(8, 4.5), dpi=96,
                     facecolor=COLORS["surface"])
        chart_t = self.chart_type.get()

        if chart_t == "heatmap":
            self._chart_heatmap(fig)
        elif chart_t == "membership":
            self._chart_membership(fig)
        else:
            self._chart_bar(fig)

        canvas = FigureCanvasTkAgg(fig, master=self.chart_frame)
        canvas.draw()
        canvas.get_tk_widget().pack(fill="both", expand=True)

    def _chart_heatmap(self, fig):
        ax = fig.add_subplot(111)
        distances = np.arange(1, 16, 2.5)
        areas = np.arange(10, 75, 12)
        Z = np.zeros((len(areas), len(distances)))
        for i, ar in enumerate(areas):
            for j, di in enumerate(distances):
                self.price_sim.input['distance']      = di
                self.price_sim.input['area']          = ar
                self.price_sim.input['hour_free']     = 12
                self.price_sim.input['people_max']    = 2
                self.price_sim.input['parking']       = 0
                self.price_sim.input['air_condition'] = 0
                self.price_sim.input['WC_private']    = 100
                self.price_sim.input['kitchen']       = 0
                self.price_sim.input['bus']           = 0
                self.price_sim.input['supermarket']   = 0
                self.price_sim.compute()
                score = self.price_sim.output['price']
                Z[i, j] = score_to_price(score) / 1_000_000

        im = ax.imshow(Z, aspect="auto", cmap="RdYlGn_r",
                       origin="lower", interpolation="bilinear")
        ax.set_xticks(range(len(distances)))
        ax.set_xticklabels([f"{d:.0f}km" for d in distances], fontsize=8)
        ax.set_yticks(range(len(areas)))
        ax.set_yticklabels([f"{a:.0f}m²" for a in areas], fontsize=8)
        ax.set_xlabel("Khoảng cách đến trường", fontsize=9)
        ax.set_ylabel("Diện tích phòng", fontsize=9)
        ax.set_title("Bản đồ nhiệt giá thuê (triệu đồng/tháng) — tiện ích cơ bản",
                     fontsize=10, fontweight="bold")
        for i in range(len(areas)):
            for j in range(len(distances)):
                ax.text(j, i, f"{Z[i,j]:.1f}", ha="center", va="center",
                        fontsize=7, color="black", fontweight="bold")
        fig.colorbar(im, ax=ax, label="Triệu đồng/tháng")
        fig.tight_layout()

