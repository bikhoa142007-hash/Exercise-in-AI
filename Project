# ─────────────────────────────────────────────
#  XÂY DỰNG HỆ THỐNG FUZZY
# ─────────────────────────────────────────────
def build_fuzzy_system():
    distance     = ctrl.Antecedent(np.arange(0, 21, 0.5), 'distance')
    area         = ctrl.Antecedent(np.arange(0, 81, 1),   'area')
    hour_free    = ctrl.Antecedent(np.arange(0, 25, 1),   'hour_free')
    people_max   = ctrl.Antecedent(np.arange(0, 7,  1),   'people_max')
    parking      = ctrl.Antecedent(np.arange(0, 101, 1),  'parking')
    air_condition= ctrl.Antecedent(np.arange(0, 101, 1),  'air_condition')
    WC_private   = ctrl.Antecedent(np.arange(0, 101, 1),  'WC_private')
    kitchen      = ctrl.Antecedent(np.arange(0, 101, 1),  'kitchen')
    bus          = ctrl.Antecedent(np.arange(0, 101, 1),  'bus')
    supermarket  = ctrl.Antecedent(np.arange(0, 101, 1),  'supermarket')
    price        = ctrl.Consequent(np.arange(0, 101, 1),  'price')

    # Membership functions – khoảng cách
    distance['close']  = fuzz.trimf(distance.universe, [0, 0, 5])
    distance['medium'] = fuzz.trimf(distance.universe, [0, 5, 10])
    distance['far']    = fuzz.trimf(distance.universe, [5, 10, 20])

    # Diện tích
    area['small']  = fuzz.trimf(area.universe, [0,  0,  40])
    area['medium'] = fuzz.trimf(area.universe, [30, 40, 60])
    area['large']  = fuzz.trimf(area.universe, [50, 60, 80])

    # Giờ tự do
    hour_free['limited'] = fuzz.trimf(hour_free.universe, [0, 0, 5])
    hour_free['plenty']  = fuzz.trimf(hour_free.universe, [5, 10, 24])

    # Số người
    people_max['few']  = fuzz.trimf(people_max.universe, [0, 0, 3])
    people_max['many'] = fuzz.trimf(people_max.universe, [3, 4, 6])

    # Các biến nhị phân (0=có, 100=không)
    for var in [parking, air_condition, WC_private, kitchen, bus, supermarket]:
        var['yes'] = fuzz.trimf(var.universe, [0,   0,   50])
        var['no']  = fuzz.trimf(var.universe, [50, 100, 100])

    # Giá
    price['low']    = fuzz.trimf(price.universe, [0,  0,  50])
    price['medium'] = fuzz.trimf(price.universe, [30, 50, 70])
    price['high']   = fuzz.trimf(price.universe, [50, 70, 100])

    rules = [
        # HIGH
        ctrl.Rule(distance['close']  & area['large'],                          price['high']),
        ctrl.Rule(distance['close']  & area['medium'],                         price['high']),
        ctrl.Rule(air_condition['yes'] & WC_private['yes'],                    price['high']),
        ctrl.Rule(kitchen['yes']     & area['large'],                          price['high']),
        ctrl.Rule(supermarket['yes'] & distance['close'],                      price['high']),
        ctrl.Rule(people_max['many'] & area['large'],                          price['high']),
        ctrl.Rule(hour_free['plenty']& parking['yes'],                         price['high']),
        ctrl.Rule(air_condition['yes'] & kitchen['yes'] & WC_private['yes'],   price['high']),
        ctrl.Rule(parking['yes']     & bus['yes'] & supermarket['yes'],        price['high']),
        ctrl.Rule(distance['close']  & air_condition['yes'],                   price['high']),
        # MEDIUM
        ctrl.Rule(distance['medium'] & area['medium'],                         price['medium']),
        ctrl.Rule(distance['far']    & area['large'],                          price['medium']),
        ctrl.Rule(kitchen['no']      & WC_private['yes'],                      price['medium']),
        ctrl.Rule(air_condition['yes'] & distance['far'],                      price['medium']),
        ctrl.Rule(bus['yes']         & distance['far'],                        price['medium']),
        ctrl.Rule(parking['yes']     & area['small'],                          price['medium']),
        ctrl.Rule(parking['no']      & distance['close'],                      price['medium']),
        ctrl.Rule(people_max['many'] & WC_private['no'],                       price['medium']),
        ctrl.Rule(distance['medium'] & WC_private['yes'],                      price['medium']),
        ctrl.Rule(area['medium']     & parking['yes'],                         price['medium']),
        ctrl.Rule(distance['close']  & area['small'] & air_condition['no'],    price['medium']),
        ctrl.Rule(distance['far']    & area['large'] & kitchen['yes'],         price['medium']),
        ctrl.Rule(supermarket['yes'] & air_condition['no'],                    price['medium']),
        ctrl.Rule(people_max['many'] & parking['no'],                          price['medium']),
        ctrl.Rule(hour_free['plenty']& distance['far'],                        price['medium']),
        ctrl.Rule(area['large']      & air_condition['no'],                    price['medium']),
        ctrl.Rule(distance['close']  & parking['no'],                          price['medium']),
        ctrl.Rule(kitchen['yes']     & WC_private['no'],                       price['medium']),
        ctrl.Rule(bus['yes']         & people_max['few'],                      price['medium']),
        ctrl.Rule(distance['medium'] & area['small'] & air_condition['yes'],   price['medium']),
        # LOW
        ctrl.Rule(distance['far']    & area['small'],                          price['low']),
        ctrl.Rule(air_condition['no']& WC_private['no'],                       price['low']),
        ctrl.Rule(bus['no']          & supermarket['no'],                      price['low']),
        ctrl.Rule(people_max['few']  & area['small'],                          price['low']),
        ctrl.Rule(hour_free['limited'],                                        price['low']),
        ctrl.Rule(distance['far']    & air_condition['no'],                    price['low']),
        ctrl.Rule(area['small']      & kitchen['no'],                          price['low']),
        ctrl.Rule(WC_private['no']   & parking['no'],                          price['low']),
        ctrl.Rule(distance['far']    & bus['no'],                              price['low']),
        ctrl.Rule(hour_free['limited'] & area['small'],                        price['low']),
    ]

    price_ctrl = ctrl.ControlSystem(rules)
    sim = ctrl.ControlSystemSimulation(price_ctrl)
    return sim


def score_to_price(score):
    """Chuyển điểm fuzzy 0-100 → giá VNĐ/tháng."""
    price_min = 800_000
    price_max = 7_000_000
    price = price_min + (score / 100) * (price_max - price_min)
    return round(price / 50_000) * 50_000


def bool_to_fuzzy(val: bool) -> int:
    """True → 0 (yes), False → 100 (no)."""
    return 0 if val else 100


def format_price(price: float) -> str:
    if price >= 1_000_000:
        return f"{price/1_000_000:.1f} triệu/tháng"
    return f"{int(price/1000)}k/tháng"


