    def _refresh_history(self):
        for row in self.hist_tree.get_children():
            self.hist_tree.delete(row)
        for i, h in enumerate(self.history):
            s = h["score"]
            tag = "low" if s < 40 else "med" if s < 65 else "high"
            self.hist_tree.insert("", "end", values=(
                i + 1,
                format_price(h["price"]),
                h["tier"].split(" ", 1)[-1],
                f"{h['distance']:.1f} km",
                f"{h['area']:.0f} m²",
                "Có" if h["ac"] else "Không",
                "Có" if h["wc"] else "Không",
                "Có" if h["kitchen"] else "Không",
                "Có" if h["parking"] else "Không",
            ), tags=(tag,))


