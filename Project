            "Xa+Vừa\n+Cơ bản":         {"distance":12,"area":35,"hour_free":12,"people_max":2,
                                         "parking":100,"air_condition":100,"WC_private":100,
                                         "kitchen":100,"bus":0,"supermarket":100},
            "Xa+Nhỏ\n+Tối giản":       {"distance":18,"area":12,"hour_free":5,"people_max":1,
                                         "parking":100,"air_condition":100,"WC_private":100,
                                         "kitchen":100,"bus":100,"supermarket":100},
        }
        labels, vals, colors = [], [], []
        palette = [COLORS["danger"], COLORS["accent"], COLORS["warn"], COLORS["text_muted"]]
        for (lbl, inp), color in zip(scenarios.items(), palette):
            for k, v in inp.items():
                self.price_sim.input[k] = v
            self.price_sim.compute()
            score = self.price_sim.output['price']
            price = score_to_price(score) / 1_000_000
            labels.append(lbl); vals.append(price); colors.append(color)

        bars = ax.bar(labels, vals, color=colors, width=0.5,
