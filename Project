        self.csv_df_result = None  # giữ kết quả để xuất

    def _process_csv(self):
        path = filedialog.askopenfilename(filetypes=[("CSV files", "*.csv")])
        if not path:
            return
        try:
            df = pd.read_csv(path)
            required = ['distance', 'area', 'hour_free', 'people_max',
                        'parking', 'air_condition', 'WC_private',
                        'kitchen', 'bus', 'supermarket']
            missing = [c for c in required if c not in df.columns]
            if missing:
                messagebox.showerror("Lỗi cột",
                    f"Thiếu các cột: {', '.join(missing)}")
                return

            for row in self.csv_tree.get_children():
                self.csv_tree.delete(row)

            scores, prices, tiers = [], [], []
            for idx, row in df.iterrows():
                for k in required:
                    self.price_sim.input[k] = float(row[k])
                self.price_sim.compute()
                score = self.price_sim.output['price']
                price = score_to_price(score)
                tier = ("Thấp" if score < 40 else
                        "Trung bình" if score < 65 else "Cao")
                scores.append(round(score, 2))
                prices.append(price)
                tiers.append(tier)
                tag = "low" if score < 40 else "med" if score < 65 else "high"
                self.csv_tree.insert("", "end", values=(
                    idx + 1,
                    f"{score:.1f}/100",
                    format_price(price),
                    tier
                ), tags=(tag,))

            self.csv_tree.tag_configure("low",  background=COLORS["warn_light"])
            self.csv_tree.tag_configure("med",  background=COLORS["accent_light"])
            self.csv_tree.tag_configure("high", background=COLORS["danger_light"])

            df["score"]  = scores
            df["price"]  = prices
            df["tier"]   = tiers
            self.csv_df_result = df
            messagebox.showinfo("Hoàn tất",
                f"Đã xử lý {len(df)} dòng.\n"
                f"Giá trung bình: {format_price(sum(prices)/len(prices))}")
        except Exception as e:
            messagebox.showerror("Lỗi", str(e))

    def _export_csv(self):
        if self.csv_df_result is None:
            messagebox.showwarning("Chưa có dữ liệu",
                                   "Vui lòng xử lý file CSV trước.")
            return
        path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            filetypes=[("CSV files", "*.csv")],
            initialfile="ket_qua_du_bao.csv")
        if path:
            self.csv_df_result.to_csv(path, index=False, encoding="utf-8-sig")
            messagebox.showinfo("Đã xuất", f"Lưu thành công:\n{path}")

