    def _section(self, parent, text):
        f = tk.Frame(parent, bg=COLORS["surface2"], height=1)
        f.pack(fill="x", padx=16, pady=(14, 4))
        tk.Label(parent, text=text, font=FONT_HEAD,
                 bg=COLORS["surface"], fg=COLORS["text"]).pack(
                 anchor="w", padx=16, pady=(4, 0))

    def _predict_single(self):
        try:
            inputs = self._collect_inputs()
            self.price_sim.input['distance']      = inputs['distance']
            self.price_sim.input['area']          = inputs['area']
            self.price_sim.input['hour_free']     = inputs['hour_free']
            self.price_sim.input['people_max']    = inputs['people_max']
            self.price_sim.input['parking']       = inputs['parking']
            self.price_sim.input['air_condition'] = inputs['air_condition']
            self.price_sim.input['WC_private']    = inputs['WC_private']
            self.price_sim.input['kitchen']       = inputs['kitchen']
            self.price_sim.input['bus']           = inputs['bus']
            self.price_sim.input['supermarket']   = inputs['supermarket']
            self.price_sim.compute()
            score = self.price_sim.output['price']
            price = score_to_price(score)

            # Xác định mức giá
            if score < 40:
                tier = "📉 Giá thấp"
                tier_color = COLORS["warn"]
                bg_color   = COLORS["warn_light"]
            elif score < 65:
                tier = "📊 Giá trung bình"
                tier_color = COLORS["accent"]
                bg_color   = COLORS["accent_light"]
            else:
                tier = "📈 Giá cao"
                tier_color = COLORS["danger"]
                bg_color   = COLORS["danger_light"]

            factors = self._get_factors(inputs)

            self.result_frame.config(bg=bg_color)
            self.lbl_price.config(text=format_price(price), bg=bg_color,
                                  fg=COLORS["accent_dark"])
            self.lbl_tier.config(text=tier, fg=tier_color, bg=bg_color)
            self.lbl_factors.config(text=factors, bg=bg_color)

            # Lưu lịch sử
            self.history.insert(0, {
                "price": price, "score": score, "tier": tier,
                "distance": inputs['distance'],
                "area": inputs['area'],
                "ac": self.tog_ac.get(),
                "wc": self.tog_wc.get(),
                "kitchen": self.tog_kitchen.get(),
                "parking": self.tog_parking.get(),
            })
            if len(self.history) > 50:
                self.history.pop()
            self._refresh_history()

        except Exception as e:
            messagebox.showerror("Lỗi", f"Hệ thống lỗi:\n{e}")

    def _collect_inputs(self) -> dict:
        return {
            'distance':      self.sl_distance.get(),
            'area':          self.sl_area.get(),
            'hour_free':     self.sl_hour_free.get(),
            'people_max':    self.sl_people_max.get(),
            'parking':       bool_to_fuzzy(self.tog_parking.get()),
            'air_condition': bool_to_fuzzy(self.tog_ac.get()),
            'WC_private':    bool_to_fuzzy(self.tog_wc.get()),
            'kitchen':       bool_to_fuzzy(self.tog_kitchen.get()),
            'bus':           bool_to_fuzzy(self.tog_bus.get()),
            'supermarket':   bool_to_fuzzy(self.tog_market.get()),
        }

    def _get_factors(self, inp) -> str:
        facts = []
        if inp['distance'] <= 3:
            facts.append("✅ Gần trường (≤3km) → tăng giá")
        elif inp['distance'] >= 10:
            facts.append("⚠️ Xa trường (≥10km) → giảm giá")
        if inp['area'] >= 50:
            facts.append("✅ Phòng rộng (≥50m²) → tăng giá")
        elif inp['area'] < 20:
            facts.append("⚠️ Phòng nhỏ (<20m²) → giảm giá")
        if inp['air_condition'] == 0:
            facts.append("✅ Có máy lạnh → tăng giá")
        else:
            facts.append("⚠️ Không máy lạnh → giảm giá")
        if inp['WC_private'] == 0:
            facts.append("✅ WC riêng → tăng giá")
        if inp['kitchen'] == 0:
            facts.append("✅ Có bếp → tăng giá")
        if inp['parking'] == 0 and inp['bus'] == 0:
            facts.append("⚠️ Không xe, không bus → giảm giá")
        if inp['supermarket'] == 0 and inp['bus'] == 0:
            facts.append("⚠️ Thiếu tiện ích khu vực → giảm giá")
        return "  |  ".join(facts) if facts else "Không có yếu tố đặc biệt."

